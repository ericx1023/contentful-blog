GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

CONTENTFUL_SPACE_ID=ljhf0uo4wt6j
CONTENTFUL_CMA_TOKEN=
CONTENTFUL_ENV=master
CONTENTFUL_TYPE=pageBlogPostWithHtml

# Bot 1 — chat IDs are pre-filled from the legacy n8n workflow; bot token is a
# secret and must NOT live in this template. Put the real value in `.env`.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_1=-1001904886242
TELEGRAM_THREAD_ID_1=4927
TELEGRAM_CHAT_ID_2=-1003394981103

# Optional second bot (@psychedelic_news_zh_bot — "台灣啟靈新聞").
# Used as a third destination if both TOKEN_2 and CHAT_ID_3 are set.
# Add the bot to your destination chat first, then paste the numeric chat ID.
TELEGRAM_BOT_TOKEN_2=
TELEGRAM_CHAT_ID_3=
TELEGRAM_THREAD_ID_3=

# Multiple feeds — comma- or whitespace-separated.
RSS_URLS="
  https://psychedelicalpha.com/feed/,
  https://psychedelicstoday.com/feed,
  https://lucid.news/feed,
  https://kahpi.net/feed,
  https://thethirdwave.co/feed,
  https://jameswjesso.com/feed,
  https://themicrodose.substack.com/feed,
  https://www.psypost.org/exclusive/drugs/psychedelic-research/feed/,
  https://www.sciencedaily.com/rss/mind_brain/psychedelic_drugs.xml
"

# Keyword filter (case-insensitive, word-boundary match against title + snippet).
# Leave KEYWORDS unset to use the built-in psychedelic vocabulary, set a custom
# comma-separated list to override, or set KEYWORD_FILTER=off to disable.
# KEYWORDS=psychedelic,psilocybin,MDMA,ayahuasca,DMT,LSD,ketamine,microdose,microdosing,ibogaine,mescaline,hallucinogen,entheogen
# KEYWORD_FILTER=off
